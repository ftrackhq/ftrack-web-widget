{
  "name": "@ftrack/web-widget",
  "packageManager": "yarn@4.12.0",
  "description": "ftrack web widget SDK",
  "main": "./dist/ftrackWidget.umd.js",
  "module": "./dist/ftrackWidget.es.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ftrackWidget.es.js",
      "require": "./dist/ftrackWidget.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "lint": "tsc && eslint . && prettier -c .",
    "test": "yarn lint",
    "build": "vite build",
    "prepack": "yarn build",
    "prepublish": "yarn test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ftrackhq/ftrack-web-widget"
  },
  "author": "ftrack",
  "license": "Apache-2.0",
  "homepage": "https://ftrack.com",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.8",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
